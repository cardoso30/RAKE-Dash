import { useState, useEffect } from "react";
import { createClient } from '@supabase/supabase-js';
import {
  LayoutDashboard, Megaphone, DollarSign, Users,
  GitBranch, FileText, CheckSquare, Bell, Settings, ChevronRight
} from "lucide-react";
import {
  AreaChart, Area, BarChart, Bar, XAxis, YAxis,
  Tooltip, ResponsiveContainer, CartesianGrid
} from "recharts";

// ─── SUPABASE ─────────────────────────────────────────────────────────────────
const supabase = createClient(
  import.meta.env.VITE_SUPABASE_URL,
  import.meta.env.VITE_SUPABASE_ANON_KEY
);

// ─── BRAND PALETTE · RAKE Identity Book V1.0 ─────────────────────────────────
const C = {
  bg:'#090909', s1:'#0E0E0E', s2:'#1C1C1C', s3:'#232323', s4:'#2A2A2A',
  border:'#2A2A2A', text:'#FFFFFF', sub:'rgba(255,255,255,0.45)', muted:'rgba(255,255,255,0.2)',
  neon:'#00FF85', neonBg:'rgba(0,255,133,0.08)', red:'#FF4455', amber:'#FFB020',
};

// Historical chart (static — atualiza manualmente conforme precisar)
const revenueData = [
  { month:'Nov', receita:52000, meta:60000 },
  { month:'Dez', receita:68000, meta:65000 },
  { month:'Jan', receita:71000, meta:70000 },
  { month:'Fev', receita:64000, meta:72000 },
  { month:'Mar', receita:82000, meta:75000 },
  { month:'Abr', receita:87400, meta:80000 },
];

const STAGES = ['Prospecção','Qualificado','Proposta','Negociação','Fechado'];
const stageColors = { Prospecção:C.sub, Qualificado:'rgba(255,255,255,0.55)', Proposta:C.amber, Negociação:C.neon, Fechado:C.neon };

// ─── HELPERS ──────────────────────────────────────────────────────────────────
const fmtFull = n => `R$ ${Number(n||0).toLocaleString('pt-BR')}`;
const fmtK    = n => `R$${(Number(n||0)/1000).toFixed(0)}k`;
const statusColor   = s => s==='ativo'?C.neon:s==='pausado'?C.amber:s==='suspenso'?C.red:s==='inativo'?C.red:C.sub;
const tierColor     = t => t==='Diamond'?C.neon:t==='Gold'?'#FFD700':t==='Silver'?'rgba(255,255,255,0.6)':'rgba(255,255,255,0.3)';
const priorityColor = p => p==='alta'?C.red:p==='media'?C.amber:C.sub;
const taskStatusColor = s => s==='concluido'?C.neon:s==='em andamento'?C.amber:C.sub;
const mono    = { fontFamily:"'DM Mono',monospace" };
const display = { fontFamily:"'Barlow Condensed',sans-serif" };
const ttStyle = { background:C.s3, border:`1px solid ${C.border}`, borderRadius:3, color:C.text, fontSize:10, fontFamily:"'DM Mono',monospace" };

// ─── ATOMS ────────────────────────────────────────────────────────────────────
const Tines = ({ size=16 }) => (
  <span style={{ ...display, fontWeight:900, letterSpacing:'-2px', fontSize:size, lineHeight:1 }}>
    <span style={{ color:C.neon,opacity:1   }}>/</span>
    <span style={{ color:C.neon,opacity:0.55}}>/</span>
    <span style={{ color:C.neon,opacity:0.25}}>/</span>
  </span>
);

const Badge = ({ text, color }) => (
  <span style={{ ...mono, display:'inline-block', fontSize:9, fontWeight:500, padding:'3px 8px',
    borderRadius:2, background:color+'18', color, letterSpacing:'0.08em', textTransform:'uppercase', whiteSpace:'nowrap' }}>
    {text}
  </span>
);

const NeonBtn = ({ children, onClick }) => (
  <button onClick={onClick} style={{ ...display, fontSize:12, fontWeight:900, letterSpacing:'0.05em',
    textTransform:'uppercase', background:C.neon, color:'#090909', border:'none',
    borderRadius:3, padding:'8px 18px', cursor:'pointer', whiteSpace:'nowrap' }}>
    {children}
  </button>
);

const GhostBtn = ({ children, onClick }) => (
  <button onClick={onClick} style={{ ...mono, fontSize:11, padding:'8px 16px', background:'transparent',
    color:C.sub, border:`1px solid ${C.border}`, borderRadius:3, cursor:'pointer' }}>
    {children}
  </button>
);

const Card = ({ children, style={} }) => (
  <div style={{ background:C.s2, border:`1px solid ${C.border}`, borderRadius:4, padding:'22px', ...style }}>
    {children}
  </div>
);

const KpiCard = ({ label, value, sub, accent=false }) => (
  <div style={{ flex:1, minWidth:0, background:accent?C.neonBg:C.s2,
    border:`1px solid ${accent?C.neon+'40':C.border}`, borderRadius:4, padding:'18px 20px' }}>
    <div style={{ ...mono, fontSize:9, color:C.muted, marginBottom:10, fontWeight:500,
      textTransform:'uppercase', letterSpacing:'0.12em' }}>{label}</div>
    <div style={{ ...display, fontSize:28, fontWeight:900, color:accent?C.neon:C.text,
      letterSpacing:'-0.5px', marginBottom:4 }}>{value}</div>
    {sub && <div style={{ ...mono, fontSize:10, color:C.sub }}>{sub}</div>}
  </div>
);

const SLabel = ({ children }) => (
  <div style={{ ...mono, fontSize:9, color:C.muted, fontWeight:500, textTransform:'uppercase',
    letterSpacing:'0.12em', marginBottom:16, display:'flex', alignItems:'center', gap:6 }}>
    <span style={{ color:C.neon }}>/</span>{children}
  </div>
);

const TH = ({ ch }) => (
  <th style={{ ...mono, fontSize:9, color:C.muted, fontWeight:500, textAlign:'left',
    padding:'8px 14px', borderBottom:`1px solid ${C.border}`,
    letterSpacing:'0.1em', textTransform:'uppercase', whiteSpace:'nowrap' }}>{ch}</th>
);

const TD = ({ children, style={} }) => (
  <td style={{ ...mono, fontSize:11, color:C.text, padding:'11px 14px',
    borderBottom:`1px solid ${C.border}`, ...style }}>{children}</td>
);

// ─── MODAL SYSTEM ─────────────────────────────────────────────────────────────
const ModalWrap = ({ title, onClose, onSave, children }) => (
  <div style={{ position:'fixed', inset:0, background:'rgba(0,0,0,0.88)',
    display:'flex', alignItems:'center', justifyContent:'center', zIndex:1000 }}
    onClick={e=>e.target===e.currentTarget&&onClose()}>
    <div style={{ background:C.s2, border:`1px solid ${C.border}`, borderRadius:6,
      padding:28, width:440, maxHeight:'90vh', overflowY:'auto' }}>
      <div style={{ display:'flex', justifyContent:'space-between', alignItems:'center', marginBottom:24 }}>
        <div style={{ ...display, fontSize:20, fontWeight:900, color:C.text }}>
          <span style={{ color:C.neon }}>/</span>{title.toUpperCase()}
        </div>
        <button onClick={onClose} style={{ background:'none', border:'none', color:C.muted, fontSize:22, cursor:'pointer', lineHeight:1 }}>×</button>
      </div>
      {children}
      <div style={{ display:'flex', justifyContent:'flex-end', gap:10, marginTop:24, paddingTop:18, borderTop:`1px solid ${C.border}` }}>
        <GhostBtn onClick={onClose}>Cancelar</GhostBtn>
        <NeonBtn onClick={onSave}>Salvar</NeonBtn>
      </div>
    </div>
  </div>
);

const FInput = ({ label, value, onChange, type='text', placeholder='' }) => (
  <div style={{ marginBottom:14 }}>
    <div style={{ ...mono, fontSize:9, color:C.muted, textTransform:'uppercase', letterSpacing:'0.1em', marginBottom:6 }}>{label}</div>
    <input type={type} value={value} onChange={e=>onChange(e.target.value)} placeholder={placeholder}
      style={{ ...mono, width:'100%', background:C.s3, border:`1px solid ${C.border}`, color:C.text,
        borderRadius:3, padding:'9px 12px', fontSize:12, outline:'none', boxSizing:'border-box' }}/>
  </div>
);

const FSelect = ({ label, value, onChange, options }) => (
  <div style={{ marginBottom:14 }}>
    <div style={{ ...mono, fontSize:9, color:C.muted, textTransform:'uppercase', letterSpacing:'0.1em', marginBottom:6 }}>{label}</div>
    <select value={value} onChange={e=>onChange(e.target.value)}
      style={{ ...mono, width:'100%', background:C.s3, border:`1px solid ${C.border}`, color:C.text,
        borderRadius:3, padding:'9px 12px', fontSize:12, outline:'none', boxSizing:'border-box' }}>
      {options.map(o=><option key={o} value={o}>{o}</option>)}
    </select>
  </div>
);

// Modal Forms
const TaskModal = ({ onSave, onClose }) => {
  const [f, setF] = useState({ title:'', priority:'media', status:'pendente', due:'', tag:'' });
  const set = k => v => setF(p=>({...p,[k]:v}));
  return (
    <ModalWrap title="Nova Tarefa" onClose={onClose} onSave={()=>f.title&&onSave(f)}>
      <FInput label="Título" value={f.title} onChange={set('title')} placeholder="Descreva a tarefa..."/>
      <FSelect label="Prioridade" value={f.priority} onChange={set('priority')} options={['alta','media','baixa']}/>
      <FSelect label="Status" value={f.status} onChange={set('status')} options={['pendente','em andamento','concluido']}/>
      <FInput label="Prazo" value={f.due} onChange={set('due')} placeholder="Ex: 25 Abr"/>
      <FInput label="Tag" value={f.tag} onChange={set('tag')} placeholder="Ex: Campanhas"/>
    </ModalWrap>
  );
};

const CampaignModal = ({ onSave, onClose }) => {
  const [f, setF] = useState({ name:'', platform:'Meta', budget:0, spent:0, cpl:0, roas:0, conv:0, status:'ativo' });
  const set = k => v => setF(p=>({...p,[k]:v}));
  const num = k => v => setF(p=>({...p,[k]:Number(v)||0}));
  return (
    <ModalWrap title="Nova Campanha" onClose={onClose} onSave={()=>f.name&&onSave(f)}>
      <FInput label="Nome" value={f.name} onChange={set('name')} placeholder="Ex: KTO — Google Ads"/>
      <FSelect label="Plataforma" value={f.platform} onChange={set('platform')} options={['Meta','Google','TikTok','YouTube','Taboola','Propeller','Outros']}/>
      <div style={{ display:'grid', gridTemplateColumns:'1fr 1fr', gap:12 }}>
        <FInput label="Budget (R$)"  value={f.budget} onChange={num('budget')} type="number"/>
        <FInput label="Gasto (R$)"   value={f.spent}  onChange={num('spent')}  type="number"/>
        <FInput label="CPL (R$)"     value={f.cpl}    onChange={num('cpl')}    type="number"/>
        <FInput label="ROAS"         value={f.roas}   onChange={num('roas')}   type="number"/>
      </div>
      <FInput label="Conversões" value={f.conv} onChange={num('conv')} type="number"/>
      <FSelect label="Status" value={f.status} onChange={set('status')} options={['ativo','pausado']}/>
    </ModalWrap>
  );
};

const DealModal = ({ defaultStage='Prospecção', onSave, onClose }) => {
  const [f, setF] = useState({ name:'', value:0, contact:'', days:0, stage:defaultStage });
  const set = k => v => setF(p=>({...p,[k]:v}));
  const num = k => v => setF(p=>({...p,[k]:Number(v)||0}));
  return (
    <ModalWrap title="Novo Deal" onClose={onClose} onSave={()=>f.name&&onSave(f)}>
      <FInput label="Nome da empresa" value={f.name}    onChange={set('name')}    placeholder="Ex: BetVip"/>
      <FInput label="Valor (R$)"      value={f.value}   onChange={num('value')}   type="number"/>
      <FInput label="Contato"         value={f.contact} onChange={set('contact')} placeholder="Ex: João P."/>
      <FInput label="Dias no funil"   value={f.days}    onChange={num('days')}    type="number"/>
      <FSelect label="Estágio" value={f.stage} onChange={set('stage')} options={STAGES}/>
    </ModalWrap>
  );
};

const ClientModal = ({ onSave, onClose }) => {
  const [f, setF] = useState({ name:'', type:'Performance', value:0, status:'ativo', renewal:'' });
  const set = k => v => setF(p=>({...p,[k]:v}));
  return (
    <ModalWrap title="Novo Contrato" onClose={onClose} onSave={()=>f.name&&onSave(f)}>
      <FInput label="Nome do cliente" value={f.name} onChange={set('name')} placeholder="Ex: Betano Brasil"/>
      <FSelect label="Modelo" value={f.type} onChange={set('type')} options={['Performance','Full Service','Mídia','Consultoria']}/>
      <FInput label="Valor Anual (R$)" value={f.value} onChange={v=>setF(p=>({...p,value:Number(v)||0}))} type="number"/>
      <FSelect label="Status" value={f.status} onChange={set('status')} options={['ativo','suspenso']}/>
      <FInput label="Próx. Renovação" value={f.renewal} onChange={set('renewal')} placeholder="Ex: Out 2026"/>
    </ModalWrap>
  );
};

const AffiliateModal = ({ onSave, onClose }) => {
  const [f, setF] = useState({ name:'', tier:'Bronze', conv:0, revenue:0, commission:0, status:'ativo', trend:'+0%', pos:true });
  const set = k => v => setF(p=>({...p,[k]:v}));
  const num = k => v => setF(p=>({...p,[k]:Number(v)||0}));
  return (
    <ModalWrap title="Novo Afiliado" onClose={onClose} onSave={()=>f.name&&onSave(f)}>
      <FInput label="Nome" value={f.name} onChange={set('name')} placeholder="Ex: Carlos Silva"/>
      <FSelect label="Tier" value={f.tier} onChange={set('tier')} options={['Diamond','Gold','Silver','Bronze']}/>
      <div style={{ display:'grid', gridTemplateColumns:'1fr 1fr', gap:12 }}>
        <FInput label="Conversões"       value={f.conv}       onChange={num('conv')}       type="number"/>
        <FInput label="Receita (R$)"     value={f.revenue}    onChange={num('revenue')}    type="number"/>
      </div>
      <FInput label="Comissão (R$)" value={f.commission} onChange={num('commission')} type="number"/>
      <FInput label="Tendência" value={f.trend} onChange={set('trend')} placeholder="Ex: +12%"/>
      <FSelect label="Status" value={f.status} onChange={set('status')} options={['ativo','inativo']}/>
    </ModalWrap>
  );
};

const LedgerModal = ({ onSave, onClose }) => {
  const [f, setF] = useState({ date:'', description:'', cat:'Receita', value:0, type:'entrada' });
  const set = k => v => setF(p=>({...p,[k]:v}));
  return (
    <ModalWrap title="Novo Lançamento" onClose={onClose} onSave={()=>f.description&&onSave(f)}>
      <FInput label="Data" value={f.date} onChange={set('date')} placeholder="Ex: 22 Abr"/>
      <FInput label="Descrição" value={f.description} onChange={set('description')} placeholder="Ex: Pagamento KTO"/>
      <FSelect label="Categoria" value={f.cat} onChange={set('cat')} options={['Receita','Afiliado','Mídia','Operacional','Outros']}/>
      <FInput label="Valor (R$)" value={f.value} onChange={v=>setF(p=>({...p,value:Number(v)||0}))} type="number"/>
      <FSelect label="Tipo" value={f.type} onChange={set('type')} options={['entrada','saída']}/>
    </ModalWrap>
  );
};

// ─── SECTIONS ─────────────────────────────────────────────────────────────────
const Overview = ({ db, openModal }) => {
  const totalIn   = db.ledger.filter(l=>l.type==='entrada').reduce((s,l)=>s+Number(l.value||0),0);
  const activeCamp= db.campaigns.filter(c=>c.status==='ativo').length;
  const activeAff = db.affiliates.filter(a=>a.status==='ativo').length;
  const totalConv = db.campaigns.reduce((s,c)=>s+Number(c.conv||0),0);
  const avgRoas   = db.campaigns.length ? (db.campaigns.reduce((s,c)=>s+Number(c.roas||0),0)/db.campaigns.length).toFixed(1) : '0';
  const pipeTotal = db.deals.reduce((s,d)=>s+Number(d.value||0),0);
  const urgent    = db.tasks.filter(t=>t.priority==='alta'&&t.status!=='concluido');

  return (
    <>
      <div style={{ display:'grid', gridTemplateColumns:'repeat(3,1fr)', gap:10, marginBottom:16 }}>
        <KpiCard label="Receita Total"    value={fmtK(totalIn)}   sub="Soma das entradas" accent/>
        <KpiCard label="Afiliados Ativos" value={activeAff}       sub={`${db.affiliates.length} cadastrados`}/>
        <KpiCard label="Campanhas Ativas" value={activeCamp}      sub={`${db.campaigns.length-activeCamp} pausadas`}/>
        <KpiCard label="Total Conversões" value={totalConv.toLocaleString('pt-BR')} sub="Todas as campanhas"/>
        <KpiCard label="ROAS Médio"       value={`${avgRoas}×`}   sub="Meta: 3.8×" accent/>
        <KpiCard label="Pipeline Total"   value={fmtK(pipeTotal)} sub={`${db.deals.length} deals`}/>
      </div>
      <div style={{ display:'flex', gap:10, marginBottom:16 }}>
        <Card style={{ flex:2 }}>
          <SLabel>Receita vs Meta — 6 meses</SLabel>
          <ResponsiveContainer width="100%" height={190}>
            <AreaChart data={revenueData}>
              <defs>
                <linearGradient id="gN" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stopColor={C.neon} stopOpacity={0.2}/>
                  <stop offset="100%" stopColor={C.neon} stopOpacity={0}/>
                </linearGradient>
              </defs>
              <CartesianGrid strokeDasharray="3 3" stroke={C.border} vertical={false}/>
              <XAxis dataKey="month" tick={{ fill:C.muted, fontSize:10, fontFamily:'DM Mono' }} axisLine={false} tickLine={false}/>
              <YAxis tick={{ fill:C.muted, fontSize:10, fontFamily:'DM Mono' }} axisLine={false} tickLine={false} tickFormatter={v=>`${v/1000}k`}/>
              <Tooltip contentStyle={ttStyle} formatter={v=>fmtFull(v)}/>
              <Area type="monotone" dataKey="receita" stroke={C.neon}  fill="url(#gN)" strokeWidth={2} name="Receita"/>
              <Area type="monotone" dataKey="meta"    stroke={C.muted} fill="none"     strokeWidth={1} strokeDasharray="5 4" name="Meta"/>
            </AreaChart>
          </ResponsiveContainer>
        </Card>
        <Card style={{ flex:1 }}>
          <SLabel>Urgente</SLabel>
          {urgent.slice(0,4).map((t,i,arr)=>(
            <div key={t.id} style={{ display:'flex', gap:10, padding:'10px 0', borderBottom:i<arr.length-1?`1px solid ${C.border}`:'none' }}>
              <div style={{ width:4, height:4, borderRadius:'50%', background:C.red, marginTop:5, flexShrink:0 }}/>
              <div>
                <div style={{ ...mono, fontSize:11, color:C.text, lineHeight:1.5 }}>{t.title}</div>
                <div style={{ ...mono, fontSize:9, color:C.muted, marginTop:3 }}>{t.due} · {t.tag}</div>
              </div>
            </div>
          ))}
          {urgent.length === 0 && <div style={{ ...mono, fontSize:11, color:C.muted }}>Nenhuma tarefa urgente.</div>}
        </Card>
      </div>
      <Card>
        <SLabel>Top Campanhas</SLabel>
        <table style={{ width:'100%', borderCollapse:'collapse' }}>
          <thead><tr>{['Campanha','Plataforma','Gasto','CPL','ROAS','Conv.','Status'].map(h=><TH key={h} ch={h}/>)}</tr></thead>
          <tbody>
            {db.campaigns.slice(0,4).map((c,i)=>(
              <tr key={c.id||i} style={{ opacity:c.status==='pausado'?0.4:1 }}>
                <TD style={{ fontWeight:600 }}>{c.name}</TD>
                <TD><Badge text={c.platform} color={C.sub}/></TD>
                <TD>{fmtFull(c.spent)}</TD>
                <TD>R$ {c.cpl}</TD>
                <TD style={{ color:c.roas>=4?C.neon:c.roas>=3?C.amber:C.red, fontWeight:700 }}>{c.roas}×</TD>
                <TD>{c.conv}</TD>
                <TD><Badge text={c.status} color={statusColor(c.status)}/></TD>
              </tr>
            ))}
          </tbody>
        </table>
      </Card>
    </>
  );
};

const Campaigns = ({ db, mutations, openModal }) => {
  const totalBudget = db.campaigns.reduce((s,c)=>s+Number(c.budget||0),0);
  const totalSpent  = db.campaigns.reduce((s,c)=>s+Number(c.spent||0),0);
  const totalConv   = db.campaigns.reduce((s,c)=>s+Number(c.conv||0),0);
  const avgRoas     = db.campaigns.length?(db.campaigns.reduce((s,c)=>s+Number(c.roas||0),0)/db.campaigns.length).toFixed(1):0;
  return (
    <>
      <div style={{ display:'flex', gap:10, marginBottom:16 }}>
        <KpiCard label="Budget Total"    value={fmtK(totalBudget)} sub=""/>
        <KpiCard label="Gasto Acumulado" value={fmtK(totalSpent)}  sub={totalBudget?`${Math.round(totalSpent/totalBudget*100)}% do budget`:'-'}/>
        <KpiCard label="Total Conv."     value={totalConv.toLocaleString()} sub=""/>
        <KpiCard label="ROAS Médio"      value={`${avgRoas}×`} sub="" accent/>
      </div>
      <Card>
        <div style={{ display:'flex', justifyContent:'space-between', alignItems:'center', marginBottom:18 }}>
          <SLabel>Campanhas</SLabel>
          <NeonBtn onClick={()=>openModal('campaign')}>+ Nova Campanha</NeonBtn>
        </div>
        <table style={{ width:'100%', borderCollapse:'collapse' }}>
          <thead><tr>{['Campanha','Plataforma','Budget','Gasto','CPL','ROAS','Conv.','Status'].map(h=><TH key={h} ch={h}/>)}</tr></thead>
          <tbody>
            {db.campaigns.map((c,i)=>{
              const pct = c.budget>0?c.spent/c.budget:0;
              return (
                <tr key={c.id||i} style={{ opacity:c.status==='pausado'?0.4:1 }}>
                  <TD style={{ fontWeight:600 }}>{c.name}</TD>
                  <TD><Badge text={c.platform} color={C.sub}/></TD>
                  <TD>{fmtFull(c.budget)}</TD>
                  <TD>
                    <div style={{ marginBottom:5 }}>{fmtFull(c.spent)}</div>
                    <div style={{ height:2, background:C.s4, borderRadius:2, width:70 }}>
                      <div style={{ height:'100%', borderRadius:2, width:`${Math.min(pct*100,100)}%`, background:pct>0.9?C.red:C.neon }}/>
                    </div>
                  </TD>
                  <TD>R$ {c.cpl}</TD>
                  <TD style={{ color:c.roas>=4?C.neon:c.roas>=3?C.amber:C.red, fontWeight:700 }}>{c.roas}×</TD>
                  <TD>{c.conv}</TD>
                  <TD>
                    <button onClick={()=>mutations.toggleCampaign(c.id,c.status)}
                      style={{ background:'none', border:'none', cursor:'pointer', padding:0 }} title="Clique para alternar status">
                      <Badge text={c.status} color={statusColor(c.status)}/>
                    </button>
                  </TD>
                </tr>
              );
            })}
          </tbody>
        </table>
      </Card>
    </>
  );
};

const Financial = ({ db, openModal }) => {
  const entries = db.ledger.filter(l=>l.type==='entrada').reduce((s,l)=>s+Number(l.value||0),0);
  const exits   = db.ledger.filter(l=>l.type==='saída').reduce((s,l)=>s+Number(l.value||0),0);
  return (
    <>
      <div style={{ display:'flex', gap:10, marginBottom:16 }}>
        <Card style={{ flex:2 }}>
          <SLabel>Receita vs Meta</SLabel>
          <ResponsiveContainer width="100%" height={210}>
            <BarChart data={revenueData} barGap={4}>
              <CartesianGrid strokeDasharray="3 3" stroke={C.border} vertical={false}/>
              <XAxis dataKey="month" tick={{ fill:C.muted, fontSize:10, fontFamily:'DM Mono' }} axisLine={false} tickLine={false}/>
              <YAxis tick={{ fill:C.muted, fontSize:10, fontFamily:'DM Mono' }} axisLine={false} tickLine={false} tickFormatter={v=>`${v/1000}k`}/>
              <Tooltip contentStyle={ttStyle} formatter={v=>fmtFull(v)}/>
              <Bar dataKey="receita" fill={C.neon} radius={[3,3,0,0]} maxBarSize={34} name="Receita"/>
              <Bar dataKey="meta"    fill={C.s4}   radius={[3,3,0,0]} maxBarSize={34} name="Meta"/>
            </BarChart>
          </ResponsiveContainer>
        </Card>
        <Card style={{ flex:1 }}>
          <SLabel>Saldo do Período</SLabel>
          <div style={{ marginBottom:16 }}>
            <div style={{ ...mono, fontSize:9, color:C.muted, marginBottom:6, textTransform:'uppercase', letterSpacing:'0.1em' }}>Entradas</div>
            <div style={{ ...display, fontSize:22, fontWeight:900, color:C.neon }}>{fmtFull(entries)}</div>
          </div>
          <div style={{ marginBottom:16 }}>
            <div style={{ ...mono, fontSize:9, color:C.muted, marginBottom:6, textTransform:'uppercase', letterSpacing:'0.1em' }}>Saídas</div>
            <div style={{ ...display, fontSize:22, fontWeight:900, color:C.red }}>{fmtFull(exits)}</div>
          </div>
          <div style={{ borderTop:`1px solid ${C.border}`, paddingTop:14 }}>
            <div style={{ ...mono, fontSize:9, color:C.muted, marginBottom:6, textTransform:'uppercase', letterSpacing:'0.1em' }}>Saldo</div>
            <div style={{ ...display, fontSize:26, fontWeight:900, color:entries-exits>=0?C.neon:C.red }}>{fmtFull(entries-exits)}</div>
          </div>
        </Card>
      </div>
      <Card>
        <div style={{ display:'flex', justifyContent:'space-between', alignItems:'center', marginBottom:18 }}>
          <SLabel>Extrato</SLabel>
          <NeonBtn onClick={()=>openModal('ledger')}>+ Lançamento</NeonBtn>
        </div>
        <table style={{ width:'100%', borderCollapse:'collapse' }}>
          <thead><tr>{['Data','Descrição','Categoria','Valor','Tipo'].map(h=><TH key={h} ch={h}/>)}</tr></thead>
          <tbody>
            {db.ledger.map((t,i)=>(
              <tr key={t.id||i}>
                <TD style={{ color:C.muted, whiteSpace:'nowrap' }}>{t.date}</TD>
                <TD style={{ color:C.text }}>{t.description}</TD>
                <TD><Badge text={t.cat} color={C.sub}/></TD>
                <TD style={{ fontWeight:700, color:t.type==='entrada'?C.neon:C.red }}>
                  {t.type==='entrada'?'+':'−'} {fmtFull(t.value)}
                </TD>
                <TD><Badge text={t.type} color={t.type==='entrada'?C.neon:C.red}/></TD>
              </tr>
            ))}
          </tbody>
        </table>
      </Card>
    </>
  );
};

const Affiliates = ({ db, openModal }) => (
  <Card>
    <div style={{ display:'flex', justifyContent:'space-between', alignItems:'center', marginBottom:18 }}>
      <SLabel>Rede de Afiliados</SLabel>
      <NeonBtn onClick={()=>openModal('affiliate')}>+ Novo Afiliado</NeonBtn>
    </div>
    <table style={{ width:'100%', borderCollapse:'collapse' }}>
      <thead><tr>{['Afiliado','Tier','Conv.','Receita','Comissão','Tend.','Status'].map(h=><TH key={h} ch={h}/>)}</tr></thead>
      <tbody>
        {db.affiliates.map((a,i)=>(
          <tr key={a.id||i}>
            <TD>
              <div style={{ display:'flex', alignItems:'center', gap:9 }}>
                <div style={{ width:26, height:26, borderRadius:3, background:C.s3,
                  border:`1px solid ${tierColor(a.tier)}40`,
                  display:'flex', alignItems:'center', justifyContent:'center',
                  ...display, fontSize:10, fontWeight:900, color:tierColor(a.tier), flexShrink:0 }}>
                  {a.name.split(' ').map(n=>n[0]).join('')}
                </div>
                <span style={{ color:C.text }}>{a.name}</span>
              </div>
            </TD>
            <TD><Badge text={a.tier} color={tierColor(a.tier)}/></TD>
            <TD>{a.conv}</TD>
            <TD style={{ fontWeight:600 }}>{fmtFull(a.revenue)}</TD>
            <TD style={{ color:C.neon, fontWeight:700 }}>{fmtFull(a.commission)}</TD>
            <TD style={{ color:a.pos?C.neon:C.red, fontWeight:700 }}>{a.trend}</TD>
            <TD><Badge text={a.status} color={statusColor(a.status)}/></TD>
          </tr>
        ))}
      </tbody>
    </table>
  </Card>
);

const PipelineCRM = ({ db, mutations, openModal }) => {
  const byStage = STAGES.reduce((acc,s)=>({ ...acc, [s]:db.deals.filter(d=>d.stage===s) }),{});
  const pipeTotal = db.deals.reduce((s,d)=>s+Number(d.value||0),0);
  const maxDeal   = db.deals.length ? Math.max(...db.deals.map(d=>Number(d.value||0))) : 0;

  return (
    <>
      <div style={{ display:'flex', gap:10, marginBottom:16 }}>
        <KpiCard label="Total Pipeline" value={fmtK(pipeTotal)} sub="" accent/>
        <KpiCard label="Em Aberto"      value={db.deals.filter(d=>d.stage!=='Fechado').length} sub=""/>
        <KpiCard label="Maior Deal"     value={fmtK(maxDeal)}  sub=""/>
        <KpiCard label="Fechados"       value={byStage['Fechado'].length} sub=""/>
      </div>
      <div style={{ display:'flex', gap:10, overflowX:'auto', paddingBottom:6 }}>
        {STAGES.map(stage=>(
          <div key={stage} style={{ minWidth:200, flex:1 }}>
            <div style={{ display:'flex', justifyContent:'space-between', alignItems:'center', marginBottom:10 }}>
              <span style={{ ...mono, fontSize:9, fontWeight:700, color:stageColors[stage], textTransform:'uppercase', letterSpacing:'0.1em' }}>/{stage}</span>
              <span style={{ ...mono, fontSize:9, color:C.muted }}>{byStage[stage].length}</span>
            </div>
            {byStage[stage].map((d,i)=>(
              <div key={d.id||i} style={{ background:C.s2, border:`1px solid ${C.border}`,
                borderLeft:`2px solid ${stageColors[stage]}`, borderRadius:3, padding:'14px 16px', marginBottom:8 }}>
                <div style={{ ...mono, fontSize:11, fontWeight:600, color:C.text, marginBottom:8 }}>{d.name}</div>
                <div style={{ ...display, fontSize:22, fontWeight:900, color:stageColors[stage], marginBottom:8 }}>{fmtK(d.value)}</div>
                <div style={{ ...mono, fontSize:9, color:C.muted, marginBottom:8 }}>{d.contact} · {d.days}d</div>
                {stage !== 'Fechado' && (
                  <div style={{ display:'flex', gap:5, flexWrap:'wrap' }}>
                    {STAGES.slice(STAGES.indexOf(stage)+1).map(next=>(
                      <button key={next} onClick={()=>mutations.updateDealStage(d.id,next)}
                        style={{ ...mono, fontSize:8, padding:'3px 7px', background:C.s4, color:C.sub,
                          border:`1px solid ${C.border}`, borderRadius:2, cursor:'pointer',
                          textTransform:'uppercase', letterSpacing:'0.05em' }}>
                        → {next}
                      </button>
                    ))}
                  </div>
                )}
              </div>
            ))}
            <button onClick={()=>openModal('deal',{ stage })}
              style={{ width:'100%', border:`1px dashed ${C.border}`, borderRadius:3, padding:'9px',
                textAlign:'center', ...mono, fontSize:9, color:C.muted, cursor:'pointer', background:'transparent' }}>
              + deal
            </button>
          </div>
        ))}
      </div>
    </>
  );
};

const Clients = ({ db, openModal }) => {
  const total  = db.clients.reduce((s,c)=>s+Number(c.value||0),0);
  const active = db.clients.filter(c=>c.status==='ativo').length;
  return (
    <Card>
      <div style={{ display:'flex', justifyContent:'space-between', alignItems:'center', marginBottom:18 }}>
        <SLabel>Contratos</SLabel>
        <NeonBtn onClick={()=>openModal('client')}>+ Novo Contrato</NeonBtn>
      </div>
      <table style={{ width:'100%', borderCollapse:'collapse' }}>
        <thead><tr>{['Cliente','Modelo','Valor Anual','Status','Próx. Renovação'].map(h=><TH key={h} ch={h}/>)}</tr></thead>
        <tbody>
          {db.clients.map((c,i)=>{
            const near=c.renewal&&(c.renewal.includes('Jun')||c.renewal.includes('Mai'));
            return (
              <tr key={c.id||i}>
                <TD style={{ color:C.text, fontWeight:700 }}>{c.name}</TD>
                <TD><Badge text={c.type} color={C.sub}/></TD>
                <TD style={{ color:C.neon, fontWeight:700 }}>{fmtFull(c.value)}</TD>
                <TD><Badge text={c.status} color={statusColor(c.status)}/></TD>
                <TD style={{ color:near?C.amber:C.sub, fontWeight:near?600:400 }}>{near&&'⚠ '}{c.renewal}</TD>
              </tr>
            );
          })}
        </tbody>
      </table>
      <div style={{ display:'flex', gap:28, padding:'16px 14px 0', borderTop:`1px solid ${C.border}`, marginTop:8 }}>
        {[
          { label:'Valor Total', value:fmtFull(total), color:C.neon },
          { label:'Ativos',      value:String(active),               color:C.text  },
          { label:'Suspensos',   value:String(db.clients.length-active), color:C.amber },
        ].map((s,i)=>(
          <div key={i}>
            <div style={{ ...mono, fontSize:9, color:C.muted, marginBottom:4, textTransform:'uppercase', letterSpacing:'0.1em' }}>{s.label}</div>
            <div style={{ ...display, fontSize:22, fontWeight:900, color:s.color }}>{s.value}</div>
          </div>
        ))}
      </div>
    </Card>
  );
};

const TasksSection = ({ db, mutations, openModal }) => {
  const [filter, setFilter] = useState('todos');
  const filtered = filter==='todos' ? db.tasks : db.tasks.filter(t=>t.status===filter);

  const cycleStatus = t => {
    const next = t.status==='pendente'?'em andamento':t.status==='em andamento'?'concluido':'pendente';
    mutations.updateTaskStatus(t.id, next);
  };

  return (
    <>
      <div style={{ display:'flex', gap:8, marginBottom:16, alignItems:'center', flexWrap:'wrap' }}>
        {['todos','pendente','em andamento','concluido'].map(f=>(
          <button key={f} onClick={()=>setFilter(f)} style={{ ...mono, fontSize:9, padding:'6px 14px',
            borderRadius:2, cursor:'pointer', fontWeight:filter===f?700:500,
            textTransform:'uppercase', letterSpacing:'0.08em',
            background:filter===f?C.neon:'transparent',
            color:filter===f?'#090909':C.sub,
            border:`1px solid ${filter===f?C.neon:C.border}` }}>
            {f}
          </button>
        ))}
        <div style={{ flex:1 }}/>
        <NeonBtn onClick={()=>openModal('task')}>+ Nova Tarefa</NeonBtn>
      </div>
      <div style={{ display:'flex', flexDirection:'column', gap:6 }}>
        {filtered.map((t,i)=>(
          <div key={t.id||i} style={{ background:C.s2, border:`1px solid ${C.border}`,
            borderLeft:`2px solid ${priorityColor(t.priority)}`,
            borderRadius:3, display:'flex', alignItems:'center', gap:14, padding:'13px 18px',
            opacity:t.status==='concluido'?0.4:1 }}>
            <button onClick={()=>cycleStatus(t)} style={{ background:'none', border:'none', cursor:'pointer', padding:0, flexShrink:0 }} title="Alterar status">
              <div style={{ width:14, height:14, borderRadius:3,
                background:t.status==='concluido'?C.neon:'transparent',
                border:`1.5px solid ${t.status==='concluido'?C.neon:t.status==='em andamento'?C.amber:C.border}` }}/>
            </button>
            <div style={{ flex:1 }}>
              <div style={{ ...mono, fontSize:12, color:C.text,
                textDecoration:t.status==='concluido'?'line-through':'none' }}>{t.title}</div>
              <div style={{ display:'flex', gap:8, marginTop:5, alignItems:'center' }}>
                {t.tag&&<Badge text={t.tag} color={C.sub}/>}
                <span style={{ ...mono, fontSize:9, color:C.muted }}>{t.due}</span>
              </div>
            </div>
            <Badge text={t.priority}  color={priorityColor(t.priority)}/>
            <Badge text={t.status}    color={taskStatusColor(t.status)}/>
          </div>
        ))}
        {filtered.length===0&&(
          <div style={{ ...mono, fontSize:11, color:C.muted, textAlign:'center', padding:'40px 0' }}>
            Nenhuma tarefa neste filtro.
          </div>
        )}
      </div>
    </>
  );
};

// ─── NAV ──────────────────────────────────────────────────────────────────────
const navItems = [
  { id:'overview',   label:'Overview',     icon:LayoutDashboard },
  { id:'campaigns',  label:'Campanhas',    icon:Megaphone       },
  { id:'financial',  label:'Financeiro',   icon:DollarSign      },
  { id:'affiliates', label:'Afiliados',    icon:Users           },
  { id:'pipeline',   label:'Pipeline CRM', icon:GitBranch       },
  { id:'clients',    label:'Clientes',     icon:FileText        },
  { id:'tasks',      label:'Tarefas',      icon:CheckSquare     },
];

// ─── ROOT ─────────────────────────────────────────────────────────────────────
export default function RakeDashboard() {
  const [section, setSection] = useState('overview');
  const [db, setDb]           = useState({ tasks:[], campaigns:[], affiliates:[], deals:[], clients:[], ledger:[] });
  const [loading, setLoading] = useState(true);
  const [modal, setModal]     = useState(null); // { type, opts }

  useEffect(() => {
    const link = document.createElement('link');
    link.rel = 'stylesheet';
    link.href = 'https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;900&family=DM+Mono:wght@400;500&display=swap';
    document.head.appendChild(link);
    loadAll();
    return () => { try { document.head.removeChild(link); } catch(e){} };
  }, []);

  const loadAll = async () => {
    setLoading(true);
    const [t,ca,af,d,cl,l] = await Promise.all([
      supabase.from('tasks').select('*').order('created_at',{ ascending:false }),
      supabase.from('campaigns').select('*').order('created_at'),
      supabase.from('affiliates').select('*').order('revenue',{ ascending:false }),
      supabase.from('deals').select('*').order('created_at'),
      supabase.from('clients').select('*').order('created_at'),
      supabase.from('ledger').select('*').order('created_at',{ ascending:false }),
    ]);
    setDb({ tasks:t.data||[], campaigns:ca.data||[], affiliates:af.data||[], deals:d.data||[], clients:cl.data||[], ledger:l.data||[] });
    setLoading(false);
  };

  // Mutations — optimistic update + Supabase sync
  const mutations = {
    updateTaskStatus: async (id, status) => {
      setDb(d=>({ ...d, tasks:d.tasks.map(t=>t.id===id?{...t,status}:t) }));
      await supabase.from('tasks').update({ status }).eq('id', id);
    },
    toggleCampaign: async (id, current) => {
      const status = current==='ativo'?'pausado':'ativo';
      setDb(d=>({ ...d, campaigns:d.campaigns.map(c=>c.id===id?{...c,status}:c) }));
      await supabase.from('campaigns').update({ status }).eq('id', id);
    },
    updateDealStage: async (id, stage) => {
      setDb(d=>({ ...d, deals:d.deals.map(dl=>dl.id===id?{...dl,stage}:dl) }));
      await supabase.from('deals').update({ stage }).eq('id', id);
    },
  };

  const handleSave = async (type, payload) => {
    const tableMap = { task:'tasks', campaign:'campaigns', deal:'deals', client:'clients', affiliate:'affiliates', ledger:'ledger' };
    const { data:r, error } = await supabase.from(tableMap[type]).insert([payload]).select().single();
    if (r && !error) {
      const key = tableMap[type];
      const prepend = ['tasks','ledger'].includes(key);
      setDb(d=>({ ...d, [key]:prepend?[r,...d[key]]:[...d[key],r] }));
    }
    setModal(null);
  };

  const openModal = (type, opts={}) => setModal({ type, opts });
  const activeLabel = navItems.find(n=>n.id===section)?.label||'';
  const sectionProps = { db, mutations, openModal };

  if (loading) return (
    <div style={{ height:'100vh', background:C.bg, display:'flex', flexDirection:'column',
      alignItems:'center', justifyContent:'center', gap:12 }}>
      <Tines size={20}/>
      <div style={{ ...display, fontSize:36, fontWeight:900, color:C.text }}>
        <span style={{ color:C.neon }}>/</span>RAKE
      </div>
      <div style={{ ...mono, fontSize:10, color:C.muted, letterSpacing:'0.1em' }}>Conectando ao banco...</div>
    </div>
  );

  return (
    <div style={{ display:'flex', height:'100vh', background:C.bg, color:C.text, fontFamily:"'DM Mono',monospace", overflow:'hidden' }}>

      {/* SIDEBAR */}
      <nav style={{ width:218, background:C.s1, borderRight:`1px solid ${C.border}`, display:'flex', flexDirection:'column', flexShrink:0 }}>
        <div style={{ padding:'22px 20px 20px', borderBottom:`1px solid ${C.border}` }}>
          <div style={{ ...display, fontSize:30, fontWeight:900, letterSpacing:'-1px', lineHeight:1, color:C.text }}>
            <span style={{ color:C.neon }}>/</span>RAKE
          </div>
          <div style={{ ...mono, fontSize:8, color:C.muted, marginTop:5, letterSpacing:'0.14em', textTransform:'uppercase' }}>
            Affiliate Agency · Casino
          </div>
        </div>
        <div style={{ padding:'12px 10px', flex:1, overflowY:'auto' }}>
          {navItems.map(item=>{
            const act = section===item.id;
            const Icon = item.icon;
            return (
              <div key={item.id} onClick={()=>setSection(item.id)} style={{
                display:'flex', alignItems:'center', gap:10, padding:'9px 12px',
                borderRadius:2, cursor:'pointer', marginBottom:1,
                background:act?C.s3:'transparent', color:act?C.text:C.sub,
                fontSize:11, fontWeight:act?500:400,
                borderLeft:`2px solid ${act?C.neon:'transparent'}`, transition:'all 0.1s' }}>
                <Icon size={12}/>{item.label}
                {act&&<ChevronRight size={10} style={{ marginLeft:'auto', color:C.neon }}/>}
              </div>
            );
          })}
        </div>
        <div style={{ padding:'16px 20px', borderTop:`1px solid ${C.border}` }}>
          <div style={{ ...mono, fontSize:11, fontWeight:500, color:C.text }}>Allan · Founder</div>
          <div style={{ ...mono, fontSize:9, color:C.muted, marginTop:2 }}>CG Group</div>
        </div>
      </nav>

      {/* MAIN */}
      <div style={{ flex:1, display:'flex', flexDirection:'column', overflow:'hidden' }}>
        <div style={{ display:'flex', alignItems:'center', justifyContent:'space-between',
          padding:'14px 26px', borderBottom:`1px solid ${C.border}`, background:C.s1 }}>
          <div style={{ display:'flex', alignItems:'center', gap:12 }}>
            <Tines size={13}/>
            <span style={{ ...display, fontWeight:900, fontSize:22, letterSpacing:'-0.3px', color:C.text }}>
              {activeLabel.toUpperCase()}
            </span>
          </div>
          <div style={{ display:'flex', gap:16, alignItems:'center' }}>
            <span style={{ ...mono, fontSize:9, color:C.muted }}>RAKE · ADMIN</span>
            <Bell     size={13} color={C.muted} style={{ cursor:'pointer' }}/>
            <Settings size={13} color={C.muted} style={{ cursor:'pointer' }}/>
          </div>
        </div>
        <div style={{ flex:1, overflow:'auto', padding:'22px 26px' }}>
          {section==='overview'   && <Overview    {...sectionProps}/>}
          {section==='campaigns'  && <Campaigns   {...sectionProps}/>}
          {section==='financial'  && <Financial   {...sectionProps}/>}
          {section==='affiliates' && <Affiliates  {...sectionProps}/>}
          {section==='pipeline'   && <PipelineCRM {...sectionProps}/>}
          {section==='clients'    && <Clients     {...sectionProps}/>}
          {section==='tasks'      && <TasksSection {...sectionProps}/>}
        </div>
      </div>

      {/* MODALS */}
      {modal?.type==='task'      && <TaskModal      onClose={()=>setModal(null)} onSave={f=>handleSave('task',f)}/>}
      {modal?.type==='campaign'  && <CampaignModal  onClose={()=>setModal(null)} onSave={f=>handleSave('campaign',f)}/>}
      {modal?.type==='deal'      && <DealModal      defaultStage={modal.opts?.stage} onClose={()=>setModal(null)} onSave={f=>handleSave('deal',f)}/>}
      {modal?.type==='client'    && <ClientModal    onClose={()=>setModal(null)} onSave={f=>handleSave('client',f)}/>}
      {modal?.type==='affiliate' && <AffiliateModal onClose={()=>setModal(null)} onSave={f=>handleSave('affiliate',f)}/>}
      {modal?.type==='ledger'    && <LedgerModal    onClose={()=>setModal(null)} onSave={f=>handleSave('ledger',f)}/>}
    </div>
  );
}
